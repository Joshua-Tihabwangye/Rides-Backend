# Database - Neon Postgres
DB_TYPE=postgres
DATABASE_URL=postgresql://evzone:evzone_secret@127.0.0.1:5435/evzone
DB_URL=postgresql://evzone:evzone_secret@127.0.0.1:5435/evzone
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=evzone
DB_PASSWORD=evzone_secret
DB_NAME=evzone
# DB_DATABASE=evzone
DB_SSL=false
DB_CONNECT_TIMEOUT_MS=15000
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY_MS=3000
DB_APP_NAME=evzone-backend
DB_FORCE_IPV4=false
DB_DNS_RESULT_ORDER=ipv4first

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_DISABLED=true

# JWT
JWT_SECRET=evzone-super-secret-change-in-production-min-32-chars-long-enough
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=evzone-uploads
S3_REGION=us-east-1

# App
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
